import "tfplan/v2" as tfplan

allowed = ["t2.micro", "t2.small"]

targets = filter tfplan.resource_changes as _, r {
  (r.type is "aws_instance" or r.type is "aws_launch_template") and
  ("create" in r.change.actions or "update" in r.change.actions)
}

violations = filter targets as _, r {
  not (r.change.after.instance_type in allowed)
}

main = rule {
  length(violations) is 0
}

